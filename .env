# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info

# ── Classifier model ──────────────────────────────────────────────────────────
# Path to the fine-tuned MiniLM model folder (output of training notebook).
# Can be relative to the project root or an absolute path.
CLASSIFIER_MODEL=training/model

# Inference device: cpu | cuda:0 | mps
CLASSIFIER_DEVICE=cpu

# Max token length (must match MAX_LENGTH used during training)
CLASSIFIER_MAX_LENGTH=128

# ── Downstream service URLs ───────────────────────────────────────────────────
SUMMARY_SERVICE_URL=http://summary-service:8001
MCQ_SERVICE_URL=http://mcq-service:8002
FLASHCARD_SERVICE_URL=http://flashcard-service:8003
TTS_SERVICE_URL=http://tts-service:8004
PLAN_SERVICE_URL=http://plan-service:8005
RAG_SERVICE_URL=http://rag-service:8006
